    { id: 'CLIC-2', articulo: 2, titulo: 'Prácticas Monopólicas Absolutas', contenido: 'Prohibidos los acuerdos entre competidores para fijar precios, limitar producción o repartirse el mercado.', libro: 'CLICAC', categoria: 'Libre Competencia' },
    { id: 'CLIC-3', articulo: 3, titulo: 'Prácticas Monopólicas Relativas', contenido: 'Incluyen negativa injustificada de venta, discriminación de precios, ventas atadas y exclusividad forzosa.', libro: 'CLICAC', categoria: 'Libre Competencia' },
    { id: 'CLIC-4', articulo: 4, titulo: 'Concentraciones Económicas', contenido: 'Las fusiones y adquisiciones que excedan ciertos umbrales deben notificarse a la CLICAC para aprobación.', libro: 'CLICAC', categoria: 'Libre Competencia' },
    { id: 'CLIC-5', articulo: 5, titulo: 'Competencia Desleal', contenido: 'Actos prohibidos: confusión, engaño, denigración, imitación sistemática y violación de secretos empresariales.', libro: 'CLICAC', categoria: 'Competencia Desleal' },
    { id: 'CLIC-6', articulo: 6, titulo: 'Sanciones por Infracciones', contenido: 'Multas de hasta el 10% de las ventas del infractor por violaciones a la libre competencia.', libro: 'CLICAC', categoria: 'Libre Competencia' },
    { id: 'CLIC-7', articulo: 7, titulo: 'Derechos del Consumidor', contenido: 'Los consumidores tienen derecho a información veraz, protección de salud, educación en consumo y reparación de daños.', libro: 'Consumidor', categoria: 'Protección al Consumidor' },
    { id: 'CLIC-8', articulo: 8, titulo: 'Publicidad Engañosa', contenido: 'Prohibida la publicidad que induzca a error sobre características, precio o calidad de productos.', libro: 'Consumidor', categoria: 'Protección al Consumidor' },
    { id: 'CLIC-9', articulo: 9, titulo: 'Garantías', contenido: 'Todo producto tiene garantía mínima de un año con derecho a reparación, reposición o devolución.', libro: 'Consumidor', categoria: 'Protección al Consumidor' },
  ],
};
