    { id: 'NI-17', articulo: 17, titulo: 'Estatuto de Roma - CPI', contenido: 'Panamá ratificó el Estatuto de Roma en 2002 aceptando la jurisdicción de la Corte Penal Internacional.', libro: 'CPI', categoria: 'Derecho Penal Internacional' },
