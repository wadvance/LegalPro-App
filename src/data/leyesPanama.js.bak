    { id: 'NI-12', articulo: 12, titulo: 'OMC - Acuerdos Comerciales', contenido: 'Panamá es miembro de la OMC desde 1997. Los acuerdos rigen el comercio internacional de bienes y servicios.', libro: 'Comercio', categoria: 'Comercio Internacional' },
