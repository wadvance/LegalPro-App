export const constitucion = {
  titulo: 'Constitución de la República de Panamá',
  descripcion: 'Constitución Política de 1972, reformada por los Actos Reformatorios de 1983, 1994 y 2004.',
  articulos: [
    { id: 'CN-1', articulo: 1, titulo: 'Soberanía', contenido: 'La Nación panameña está organizada en Estado soberano e independiente, cuya denominación es República de Panamá.', libro: 'Título I', categoria: 'Disposiciones Fundamentales' },
    { id: 'CN-2', articulo: 2, titulo: 'División de Poderes', contenido: 'El Gobierno de la República de Panamá se ejerce por tres órganos: el Legislativo, el Ejecutivo y el Judicial, coordinados entre sí y con funciones separadas.', libro: 'Título I', categoria: 'Disposiciones Fundamentales' },
    { id: 'CN-3', articulo: 3, titulo: 'Territorio', contenido: 'El territorio de Panamá comprende la superficie terrestre, el mar territorial, la plataforma continental y el espacio aéreo.', libro: 'Título I', categoria: 'Disposiciones Fundamentales' },
    { id: 'CN-17', articulo: 17, titulo: 'Derechos Individuales', contenido: 'Los derechos y garantías que consagra la Constitución se consideran mínimos y no excluyen otros derechos fundamentales de la persona.', libro: 'Título III', categoria: 'Derechos y Garantías' },
    { id: 'CN-19', articulo: 19, titulo: 'Igualdad', contenido: 'No habrá fueros personales ni discriminación por razón de raza, nacimiento, discapacidad, clase social, sexo, religión o ideas políticas.', libro: 'Título III', categoria: 'Derechos y Garantías' },
    { id: 'CN-20', articulo: 20, titulo: 'Debido Proceso', contenido: 'Toda persona tiene derecho a ser oída en un plazo razonable por un tribunal competente, independiente e imparcial.', libro: 'Título III', categoria: 'Derechos y Garantías' },
    { id: 'CN-21', articulo: 21, titulo: 'Libertad Personal', contenido: 'Nadie puede ser detenido sino por mandamiento escrito de autoridad judicial. La detención preventiva no excederá de 48 horas.', libro: 'Título III', categoria: 'Derechos y Garantías' },
    { id: 'CN-22', articulo: 22, titulo: 'Inviolabilidad de la Vivienda', contenido: 'La vivienda es inviolable. Nadie puede penetrar en ella sin consentimiento del morador o sin mandamiento judicial.', libro: 'Título III', categoria: 'Derechos y Garantías' },
    { id: 'CN-23', articulo: 23, titulo: 'Habeas Corpus', contenido: 'Toda persona detenida ilegalmente tiene derecho a solicitar Habeas Corpus ante el Tribunal Superior de Justicia.', libro: 'Título III', categoria: 'Derechos y Garantías' },
    { id: 'CN-24', articulo: 24, titulo: 'Libertad de Expresión', contenido: 'Toda persona tiene derecho a expresar libremente su pensamiento mediante la palabra, la escritura o cualquier otro medio.', libro: 'Título III', categoria: 'Derechos y Garantías' },
    { id: 'CN-25', articulo: 25, titulo: 'Libertad de Reunión', contenido: 'Toda persona tiene derecho de reunirse pacíficamente y sin armas para fines lícitos, sin necesidad de permiso previo.', libro: 'Título III', categoria: 'Derechos y Garantías' },
    { id: 'CN-26', articulo: 26, titulo: 'Libertad de Asociación', contenido: 'Toda persona tiene derecho a formar asociaciones para fines lícitos, sin necesidad de autorización previa.', libro: 'Título III', categoria: 'Derechos y Garantías' },
    { id: 'CN-27', articulo: 27, titulo: 'Libertad de Culto', contenido: 'Toda persona puede profesar libremente su religión y practicar sus creencias sin más limitaciones que el orden público y el respeto a la moral.', libro: 'Título III', categoria: 'Derechos y Garantías' },
    { id: 'CN-28', articulo: 28, titulo: 'Derecho de Petición', contenido: 'Toda persona tiene derecho a presentar peticiones respetuosas a las autoridades y a obtener pronta resolución.', libro: 'Título III', categoria: 'Derechos y Garantías' },
    { id: 'CN-29', articulo: 29, titulo: 'Derecho a la Propiedad', contenido: 'Se garantiza la propiedad privada adquirida conforme a la ley. La expropiación solo procede por causa de utilidad pública o interés social, mediante indemnización.', libro: 'Título III', categoria: 'Derechos Económicos' },
    { id: 'CN-30', articulo: 30, titulo: 'Libertad de Trabajo', contenido: 'Toda persona tiene derecho al trabajo y a dedicarse a la actividad económica de su preferencia, sin más limitaciones que las establecidas por la ley.', libro: 'Título III', categoria: 'Derechos Económicos' },
    { id: 'CN-40', articulo: 40, titulo: 'Derecho a la Salud', contenido: 'Toda persona tiene derecho a la salud. El Estado garantiza el acceso universal a los servicios de salud pública.', libro: 'Título III', categoria: 'Derechos Sociales' },
    { id: 'CN-41', articulo: 41, titulo: 'Derecho a la Educación', contenido: 'La educación es un derecho de la persona y un deber del Estado. La educación primaria es obligatoria y gratuita.', libro: 'Título III', categoria: 'Derechos Sociales' },
    { id: 'CN-100', articulo: 100, titulo: 'Organo Legislativo', contenido: 'El Organo Legislativo está constituido por la Asamblea Nacional, elegida por votación popular directa para un período de cinco años.', libro: 'Título V', categoria: 'Organización del Estado' },
    { id: 'CN-101', articulo: 101, titulo: 'Funciones de la Asamblea', contenido: 'Corresponde a la Asamblea Nacional: expedir leyes, aprobar el presupuesto del Estado, ratificar tratados internacionales, y ejercer control político sobre el Ejecutivo.', libro: 'Título V', categoria: 'Organización del Estado' },
    { id: 'CN-150', articulo: 150, titulo: 'Organo Ejecutivo', contenido: 'El Organo Ejecutivo está constituido por el Presidente de la República y los Ministros de Estado. El Presidente es elegido por votación popular directa por cinco años.', libro: 'Título VI', categoria: 'Organización del Estado' },
    { id: 'CN-151', articulo: 151, titulo: 'Funciones del Presidente', contenido: 'El Presidente de la República ejerce la jefatura del Estado y del Gobierno, representa a la Nación, y dirige la administración pública.', libro: 'Título VI', categoria: 'Organización del Estado' },
    { id: 'CN-200', articulo: 200, titulo: 'Organo Judicial', contenido: 'El Organo Judicial está constituido por la Corte Suprema de Justicia, los tribunales superiores y los juzgados. La función jurisdiccional se ejerce con independencia.', libro: 'Título VII', categoria: 'Organización del Estado' },
    { id: 'CN-201', articulo: 201, titulo: 'Corte Suprema de Justicia', contenido: 'La Corte Suprema de Justicia es el máximo tribunal de la República. Está integrada por nueve magistrados designados por el Presidente con aprobación de la Asamblea.', libro: 'Título VII', categoria: 'Organización del Estado' },
    { id: 'CN-202', articulo: 202, titulo: 'Funciones de la Corte Suprema', contenido: 'La Corte Suprema conoce de los recursos de casación, habeas corpus, amparo de garantías, inconstitucionalidad de leyes, y los conflictos entre órganos del Estado.', libro: 'Título VII', categoria: 'Organización del Estado' },
    { id: 'CN-203', articulo: 203, titulo: 'Amparo de Garantías', contenido: 'Toda persona puede interponer acción de amparo de garantías contra cualquier orden, acto o disposición que viole los derechos constitucionales.', libro: 'Título VII', categoria: 'Organización del Estado' },
    { id: 'CN-204', articulo: 204, titulo: 'Inconstitucionalidad', contenido: 'Cuando una ley o decreto viole un precepto constitucional, cualquier persona puede solicitar su declaratoria de inconstitucionalidad ante la Corte Suprema.', libro: 'Título VII', categoria: 'Organización del Estado' },
    { id: 'CN-300', articulo: 300, titulo: 'Provincias y Distritos', contenido: 'La República se divide políticamente en provincias, estas en distritos y estos en corregimientos. La ley fijará su número y límites.', libro: 'Título IX', categoria: 'Organización Territorial' },
    { id: 'CN-301', articulo: 301, titulo: 'Régimen Municipal', contenido: 'Los municipios son autónomos política, administrativa y económicamente. Su gobierno corresponde al alcalde y al concejo municipal.', libro: 'Título IX', categoria: 'Organización Territorial' },
  ],
};

export const codigoFamilia = {
  titulo: 'Código de la Familia de la República de Panamá',
  descripcion: 'Ley 3 de 17 de mayo de 1994, que regula las relaciones familiares en Panamá.',
  articulos: [
    { id: 'CF-1', articulo: 1, titulo: 'Objeto del Código', contenido: 'El presente Código tiene por objeto regular las relaciones jurídicas derivadas de la familia y de los menores.', libro: 'Libro I', categoria: 'Disposiciones Generales' },
    { id: 'CF-2', articulo: 2, titulo: 'Protección de la Familia', contenido: 'El Estado protege a la familia como institución fundamental de la sociedad. La familia debe fundarse en el respeto, la solidaridad y la igualdad de derechos.', libro: 'Libro I', categoria: 'Disposiciones Generales' },
    { id: 'CF-10', articulo: 10, titulo: 'Matrimonio Civil', contenido: 'El matrimonio civil es la unión voluntaria entre un hombre y una mujer, con aptitud legal, para hacer vida en común. Debe celebrarse ante autoridad competente.', libro: 'Libro II', categoria: 'Matrimonio' },
    { id: 'CF-11', articulo: 11, titulo: 'Requisitos del Matrimonio', contenido: 'Para contraer matrimonio se requiere: ser mayor de 18 años, consentimiento libre y voluntario, y la presencia de dos testigos hábiles.', libro: 'Libro II', categoria: 'Matrimonio' },
    { id: 'CF-12', articulo: 12, titulo: 'Divorcio por Mutuo Acuerdo', contenido: 'El divorcio por mutuo acuerdo puede solicitarse después de un año de matrimonio. Los cónyuges deben presentar un acuerdo sobre la distribución de bienes y la custodia de los hijos.', libro: 'Libro II', categoria: 'Matrimonio' },
    { id: 'CF-13', articulo: 13, titulo: 'Divorcio por Causales', contenido: 'Son causales de divorcio: el adulterio, la sevicia, las amenazas graves, el abandono voluntario y la separación de hecho por más de dos años.', libro: 'Libro II', categoria: 'Matrimonio' },
    { id: 'CF-20', articulo: 20, titulo: 'Unión de Hecho', contenido: 'La unión de hecho estable y permanente entre un hombre y una mujer, con capacidad legal, que mantengan hogar común por más de cinco años, produce efectos legales similares al matrimonio.', libro: 'Libro II', categoria: 'Matrimonio' },
    { id: 'CF-30', articulo: 30, titulo: 'Filiación', contenido: 'La filiación es la relación jurídica entre padres e hijos. Puede ser por naturaleza o por adopción. Todos los hijos tienen iguales derechos.', libro: 'Libro III', categoria: 'Filiación' },
    { id: 'CF-31', articulo: 31, titulo: 'Reconocimiento de Hijos', contenido: 'El reconocimiento de los hijos es un acto voluntario que puede hacerse en el Registro Civil, en testamento o en escritura pública.', libro: 'Libro III', categoria: 'Filiación' },
    { id: 'CF-32', articulo: 32, titulo: 'Investigación de Paternidad', contenido: 'Toda persona tiene derecho a investigar judicialmente su filiación. La acción de investigación de paternidad es imprescriptible.', libro: 'Libro III', categoria: 'Filiación' },
    { id: 'CF-40', articulo: 40, titulo: 'Patria Potestad', contenido: 'La patria potestad comprende el cuidado, la educación, la protección y la representación de los hijos menores. Se ejerce conjuntamente por ambos padres.', libro: 'Libro IV', categoria: 'Patria Potestad' },
    { id: 'CF-41', articulo: 41, titulo: 'Suspensión de la Patria Potestad', contenido: 'La patria potestad se suspende por: demencia, ausencia injustificada por más de seis meses, maltrato grave al hijo, y condena penal con pena de prisión.', libro: 'Libro IV', categoria: 'Patria Potestad' },
    { id: 'CF-42', articulo: 42, titulo: 'Custodia', contenido: 'En caso de separación o divorcio, la custodia de los hijos se determinará considerando el interés superior del menor. Se favorecerá la custodia compartida.', libro: 'Libro IV', categoria: 'Patria Potestad' },
    { id: 'CF-50', articulo: 50, titulo: 'Obligación Alimentaria', contenido: 'Los padres deben alimentos a sus hijos y los hijos a sus padres. La obligación alimentaria comprende: alimentación, vivienda, vestido, educación, salud y recreación.', libro: 'Libro V', categoria: 'Alimentos' },
    { id: 'CF-51', articulo: 51, titulo: 'Fijación de Alimentos', contenido: 'La cuota alimentaria se fija considerando las necesidades del alimentario y las posibilidades del obligado. No podrá exceder del 50% del salario del obligado.', libro: 'Libro V', categoria: 'Alimentos' },
    { id: 'CF-52', articulo: 52, titulo: 'Proceso de Alimentos', contenido: 'El proceso de alimentos es preferente y sumario. El juez puede ordenar el pago provisional de alimentos desde la admisión de la demanda.', libro: 'Libro V', categoria: 'Alimentos' },
    { id: 'CF-60', articulo: 60, titulo: 'Adopción', contenido: 'La adopción es una institución que tiene por objeto proporcionar una familia al menor que carece de ella. La adopción se constituye por resolución judicial.', libro: 'Libro VI', categoria: 'Adopción' },
    { id: 'CF-61', articulo: 61, titulo: 'Requisitos para Adoptar', contenido: 'Para adoptar se requiere: ser mayor de 25 años, tener capacidad legal, estar en condiciones morales y económicas, y tener diferencia de edad de al menos 15 años con el adoptado.', libro: 'Libro VI', categoria: 'Adopción' },
    { id: 'CF-70', articulo: 70, titulo: 'Menores en Riesgo', contenido: 'El Estado protegerá a los menores en situación de riesgo social. Las medidas de protección incluyen: orientación, apoyo familiar, colocación familiar y acogimiento residencial.', libro: 'Libro VII', categoria: 'Protección de Menores' },
    { id: 'CF-71', articulo: 71, titulo: 'Maltrato Infantil', contenido: 'Todo acto de maltrato físico, psicológico o sexual contra un menor será sancionado conforme a la ley. La autoridad competente debe intervenir de oficio.', libro: 'Libro VII', categoria: 'Protección de Menores' },
  ],
};

export const codigoFiscal = {
  titulo: 'Código Fiscal de la República de Panamá',
  descripcion: 'Ley 8 de 1956, Código Fiscal de la República de Panamá y sus modificaciones.',
  articulos: [
    { id: 'CFI-1', articulo: 1, titulo: 'Sistema Tributario', contenido: 'El sistema tributario panameño se fundamenta en los principios de legalidad, igualdad, equidad y capacidad contributiva.', libro: 'Libro I', categoria: 'Principios Tributarios' },
    { id: 'CFI-2', articulo: 2, titulo: 'Impuesto sobre la Renta', contenido: 'Toda persona natural o jurídica que obtenga ingresos de fuente panameña está sujeta al impuesto sobre la renta, conforme a las tarifas establecidas por la ley.', libro: 'Libro II', categoria: 'Impuesto sobre la Renta' },
    { id: 'CFI-3', articulo: 3, titulo: 'Rentas de Fuente Panameña', contenido: 'Se consideran de fuente panameña las rentas provenientes de bienes situados en Panamá o de actividades desarrolladas en el territorio nacional.', libro: 'Libro II', categoria: 'Impuesto sobre la Renta' },
    { id: 'CFI-4', articulo: 4, titulo: 'Tarifa del ISR', contenido: 'Las personas jurídicas pagan el 25% sobre su renta neta gravable. Las personas naturales pagan tarifas progresivas desde 0% hasta 27%.', libro: 'Libro II', categoria: 'Impuesto sobre la Renta' },
    { id: 'CFI-5', articulo: 5, titulo: 'ITBMS', contenido: 'El Impuesto a la Transferencia de Bienes Muebles y Servicios (ITBMS) es del 7% y se aplica a la venta de bienes y prestación de servicios en el territorio nacional.', libro: 'Libro III', categoria: 'ITBMS' },
    { id: 'CFI-6', articulo: 6, titulo: 'ITBMS Exento', contenido: 'Están exentos del ITBMS: los alimentos básicos, los medicamentos, los libros, los servicios educativos y de salud, y las exportaciones.', libro: 'Libro III', categoria: 'ITBMS' },
    { id: 'CFI-7', articulo: 7, titulo: 'Impuesto de Inmueble', contenido: 'El impuesto de inmueble se aplica sobre el valor catastral de la propiedad. La tasa es del 2.10% para propiedades urbanas y 1.05% para propiedades rurales.', libro: 'Libro IV', categoria: 'Impuesto de Inmueble' },
    { id: 'CFI-8', articulo: 8, titulo: 'Exención de Inmueble', contenido: 'Están exentos del impuesto de inmueble: las propiedades del Estado, las iglesias, los partidos políticos, y las viviendas con valor catastral hasta B/.30,000.', libro: 'Libro IV', categoria: 'Impuesto de Inmueble' },
    { id: 'CFI-9', articulo: 9, titulo: 'Impuesto de Inmueble Progresivo', contenido: 'Las propiedades con valor catastral superior a B/.300,000 pagan una tasa progresiva adicional que puede llegar hasta el 3.5% del excedente.', libro: 'Libro IV', categoria: 'Impuesto de Inmueble' },
    { id: 'CFI-10', articulo: 10, titulo: 'Impuesto de Importación', contenido: 'Los derechos de importación se aplican a las mercancías que ingresan al territorio nacional, conforme al Arancel de Aduanas vigente.', libro: 'Libro V', categoria: 'Aduanas' },
    { id: 'CFI-11', articulo: 11, titulo: 'Zonas Francas', contenido: 'Las zonas francas son áreas exentas de impuestos de importación y exportación. Las empresas instaladas en zonas francas gozan de beneficios fiscales especiales.', libro: 'Libro V', categoria: 'Aduanas' },
    { id: 'CFI-12', articulo: 12, titulo: 'Sedes de Empresas', contenido: 'Las sedes de empresas multinacionales establecidas en Panamá gozan de exención del impuesto sobre la renta por los ingresos de fuente extranjera.', libro: 'Libro VI', categoria: 'Regímenes Especiales' },
    { id: 'CFI-13', articulo: 13, titulo: 'Fondo de Ahorro de Panamá', contenido: 'Los ingresos generados por el Fondo de Ahorro de Panamá están exentos del impuesto sobre la renta.', libro: 'Libro VI', categoria: 'Regímenes Especiales' },
    { id: 'CFI-14', articulo: 14, titulo: 'Retención en la Fuente', contenido: 'Los empleadores deben retener el impuesto sobre la renta de sus empleados y pagarlo a la Dirección General de Ingresos mensualmente.', libro: 'Libro VII', categoria: 'Administración Tributaria' },
    { id: 'CFI-15', articulo: 15, titulo: 'Declaración de Renta', contenido: 'Las personas naturales y jurídicas deben presentar declaración de renta anual dentro de los tres meses siguientes al cierre del año fiscal.', libro: 'Libro VII', categoria: 'Administración Tributaria' },
    { id: 'CFI-16', articulo: 16, titulo: 'Prescripción Fiscal', contenido: 'La obligación tributaria prescribe a los 5 años contados desde la fecha en que el tributo era exigible.', libro: 'Libro VII', categoria: 'Administración Tributaria' },
    { id: 'CFI-17', articulo: 17, titulo: 'Infracciones Tributarias', contenido: 'La evasión fiscal, la defraudación tributaria y el incumplimiento de las obligaciones formales serán sancionados con multas.', libro: 'Libro VIII', categoria: 'Infracciones y Sanciones' },
    { id: 'CFI-18', articulo: 18, titulo: 'Procedimiento de Fiscalización', contenido: 'La Dirección General de Ingresos puede fiscalizar a los contribuyentes mediante auditorías y requerimientos de información. El contribuyente debe colaborar con la fiscalización.', libro: 'Libro VIII', categoria: 'Infracciones y Sanciones' },
  ],
};

export const leyesEspeciales = {
  titulo: 'Leyes Especiales de la República de Panamá',
  descripcion: 'Compilación de leyes especiales panameñas de diversas materias.',
  articulos: [
    { id: 'LE-1', articulo: 1, titulo: 'Ley de Propiedad Industrial', contenido: 'La Ley 35 de 2007 regula la propiedad industrial en Panamá, incluyendo patentes, marcas, diseños industriales y denominaciones de origen.', libro: 'Propiedad Industrial', categoria: 'Propiedad Intelectual' },
    { id: 'LE-2', articulo: 2, titulo: 'Patentes de Invención', contenido: 'Las patentes se conceden por 20 años para invenciones nuevas, con nivel inventivo y aplicación industrial. Las patentes de modelo de utilidad se conceden por 10 años.', libro: 'Propiedad Industrial', categoria: 'Propiedad Intelectual' },
    { id: 'LE-3', articulo: 3, titulo: 'Registro de Marcas', contenido: 'El registro de marca se concede por 10 años, renovables por períodos iguales. La marca puede ser nominativa, figurativa, mixta o tridimensional.', libro: 'Propiedad Industrial', categoria: 'Propiedad Intelectual' },
    { id: 'LE-4', articulo: 4, titulo: 'Derecho de Autor', contenido: 'La Ley 15 de 1994 protege los derechos de autor sobre obras literarias, artísticas y científicas. La protección dura toda la vida del autor más 50 años después de su muerte.', libro: 'Derecho de Autor', categoria: 'Propiedad Intelectual' },
    { id: 'LE-5', articulo: 5, titulo: 'Ley de Contrataciones Públicas', contenido: 'La Ley 22 de 2006 regula las contrataciones del Estado panameño. Los principios son: transparencia, publicidad, igualdad, competencia y eficiencia.', libro: 'Contrataciones', categoria: 'Contrataciones Públicas' },
    { id: 'LE-6', articulo: 6, titulo: 'Tipos de Contratación', contenido: 'Las contrataciones públicas pueden ser: licitación pública, licitación por mejor valor, licitación de menor cuantía, acto público y contratación directa.', libro: 'Contrataciones', categoria: 'Contrataciones Públicas' },
    { id: 'LE-7', articulo: 7, titulo: 'Sistema de Inhabilitación', contenido: 'Los contratistas que incumplan sus obligaciones contractuales con el Estado serán inhabilitados para contratar por períodos de hasta 5 años.', libro: 'Contrataciones', categoria: 'Contrataciones Públicas' },
    { id: 'LE-8', articulo: 8, titulo: 'Ley de Protección al Consumidor', contenido: 'La Ley 45 de 2007 protege los derechos de los consumidores en Panamá, incluyendo: información veraz, garantías, y protección contra publicidad engañosa.', libro: 'Consumidor', categoria: 'Protección al Consumidor' },
    { id: 'LE-9', articulo: 9, titulo: 'Garantía de Productos', contenido: 'Todo producto tiene garantía mínima de un año. El fabricante y el vendedor son solidariamente responsables por los defectos del producto.', libro: 'Consumidor', categoria: 'Protección al Consumidor' },
    { id: 'LE-10', articulo: 10, titulo: 'Ley Ambiental', contenido: 'La Ley 41 de 1998 establece los principios de la gestión ambiental en Panamá, incluyendo: evaluación de impacto ambiental, conservación de recursos y participación ciudadana.', libro: 'Ambiental', categoria: 'Derecho Ambiental' },
    { id: 'LE-11', articulo: 11, titulo: 'Evaluación de Impacto Ambiental', contenido: 'Todo proyecto que pueda afectar el ambiente debe presentar un estudio de impacto ambiental ante el Ministerio de Ambiente.', libro: 'Ambiental', categoria: 'Derecho Ambiental' },
    { id: 'LE-12', articulo: 12, titulo: 'Delitos Ambientales', contenido: 'Constituyen delitos ambientales: la contaminación, la tala ilegal, el tráfico de fauna silvestre, y el daño a ecosistemas protegidos.', libro: 'Ambiental', categoria: 'Derecho Ambiental' },
    { id: 'LE-13', articulo: 13, titulo: 'Ley de Inmigración', contenido: 'El Decreto Ley 3 de 2008 regula la entrada, permanencia y salida de extranjeros del territorio nacional, así como las categorías migratorias.', libro: 'Inmigración', categoria: 'Inmigración' },
    { id: 'LE-14', articulo: 14, titulo: 'Categorías Migratorias', contenido: 'Las categorías migratorias incluyen: turista, residente temporal, residente permanente, inversionista, pensionado, y refugiado.', libro: 'Inmigración', categoria: 'Inmigración' },
    { id: 'LE-15', articulo: 15, titulo: 'Ley de Bancos', contenido: 'El Decreto Ley 2 de 2008 regula el sistema bancario panameño. La Superintendencia de Bancos es la entidad reguladora y supervisora.', libro: 'Bancario', categoria: 'Derecho Bancario' },
    { id: 'LE-16', articulo: 16, titulo: 'Secreto Bancario', contenido: 'Panamá tiene secreto bancario. La información de los clientes bancarios es confidencial y solo puede ser revelada por orden judicial o autorización del cliente.', libro: 'Bancario', categoria: 'Derecho Bancario' },
    { id: 'LE-17', articulo: 17, titulo: 'Ley de Sociedades Anónimas', contenido: 'La Ley 32 de 1927 regula la constitución y funcionamiento de las sociedades anónimas en Panamá, incluyendo el régimen de acciones nominativas.', libro: 'Sociedades', categoria: 'Sociedades' },
    { id: 'LE-18', articulo: 18, titulo: 'Sociedades de Acciones Nominativas', contenido: 'Toda sociedad anónima constituida en Panamá debe tener acciones nominativas. Se prohíben las acciones al portador.', libro: 'Sociedades', categoria: 'Sociedades' },
    { id: 'LE-19', articulo: 19, titulo: 'Ley de la Caja de Seguro Social', contenido: 'La Ley 51 de 2005 regula el sistema de seguridad social en Panamá, administrado por la Caja de Seguro Social, que cubre riesgos de enfermedad, vejez, invalidez y muerte.', libro: 'Seguridad Social', categoria: 'Seguridad Social' },
    { id: 'LE-20', articulo: 20, titulo: 'Régimen de Ahorro Voluntario', contenido: 'El Régimen de Ahorro Voluntario permite a los trabajadores realizar aportes voluntarios adicionales para mejorar su pensión de jubilación.', libro: 'Seguridad Social', categoria: 'Seguridad Social' },
    { id: 'LE-21', articulo: 21, titulo: 'Ley de Municipios', contenido: 'La Ley 106 de 1973 regula la organización y funcionamiento de los municipios en Panamá, estableciendo sus competencias y recursos.', libro: 'Municipal', categoria: 'Derecho Municipal' },
    { id: 'LE-22', articulo: 22, titulo: 'Tasas Municipales', contenido: 'Los municipios pueden establecer tasas por servicios como: recolección de basura, permiso de construcción, avisos comerciales y uso de espacios públicos.', libro: 'Municipal', categoria: 'Derecho Municipal' },
    { id: 'LE-23', articulo: 23, titulo: 'Ley de Arbitraje', contenido: 'El Decreto Ley 5 de 1999 regula el arbitraje comercial en Panamá. Las partes pueden someter sus controversias a arbitraje de derecho o de equidad.', libro: 'Arbitraje', categoria: 'Medios Alternos' },
    { id: 'LE-24', articulo: 24, titulo: 'Laudo Arbitral', contenido: 'El laudo arbitral es definitivo, obligatorio e inapelable. Tiene efecto de cosa juzgada y puede ejecutarse como una sentencia judicial.', libro: 'Arbitraje', categoria: 'Medios Alternos' },
    { id: 'LE-25', articulo: 25, titulo: 'Ley de Mediación', contenido: 'La Ley 16 de 2013 regula la mediación como método alterno de solución de conflictos. La mediación es voluntaria y confidencial.', libro: 'Mediación', categoria: 'Medios Alternos' },
    { id: 'LE-26', articulo: 26, titulo: 'Ley de Transparencia', contenido: 'La Ley 6 de 2002 garantiza el acceso a la información pública en Panamá. Toda persona tiene derecho a solicitar información a las entidades públicas sin necesidad de justificar su solicitud.', libro: 'Transparencia', categoria: 'Derecho Administrativo' },
    { id: 'LE-27', articulo: 27, titulo: 'Procedimiento Administrativo', contenido: 'La Ley 38 de 2000 regula el procedimiento administrativo general en Panamá, estableciendo los principios de debido proceso, celeridad y economía procesal.', libro: 'Administrativo', categoria: 'Derecho Administrativo' },
    { id: 'LE-28', articulo: 28, titulo: 'Recursos Administrativos', contenido: 'Contra los actos administrativos proceden los recursos de reconsideración, apelación y revisión, según el caso.', libro: 'Administrativo', categoria: 'Derecho Administrativo' },
    { id: 'LE-29', articulo: 29, titulo: 'Ley de la Carrera Judicial', contenido: 'La Ley 53 de 2015 regula la carrera judicial en Panamá, basada en los principios de mérito, capacidad, idoneidad y transparencia.', libro: 'Judicial', categoria: 'Organización Judicial' },
    { id: 'LE-30', articulo: 30, titulo: 'Código de Ética Judicial', contenido: 'Los jueces y magistrados deben actuar con independencia, imparcialidad, integridad, transparencia y diligencia en el ejercicio de sus funciones.', libro: 'Judicial', categoria: 'Organización Judicial' },
  ],
};
