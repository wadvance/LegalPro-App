    { id: 'NI-6', articulo: 6, titulo: 'Convención CEDAW', contenido: 'La Convención sobre Eliminación de Discriminación contra la Mujer fue ratificada por Panamá en 1981.', libro: 'DD.HH.', categoria: 'Derechos Humanos' },
