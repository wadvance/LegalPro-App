    { id: 'NI-20', articulo: 20, titulo: 'Acuerdo de París', contenido: 'Panamá ratificó el Acuerdo de París sobre cambio climático comprometiéndose a reducir emisiones.', libro: 'Ambiental', categoria: 'Derecho Ambiental Internacional' },
    { id: 'NI-21', articulo: 21, titulo: 'Tratados Torrijos-Carter', contenido: 'Los Tratados de 1977 establecieron la devolución del Canal de Panamá y su neutralidad permanente.', libro: 'Canal', categoria: 'Tratados' },
